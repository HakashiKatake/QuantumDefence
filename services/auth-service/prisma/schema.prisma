datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String     // Commander, Operator, Analyst, Admin
  createdAt DateTime   @default(now())
  logs      AuditLog[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  resource  String
  details   String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
