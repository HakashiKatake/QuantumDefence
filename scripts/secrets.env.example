# ============================================================
# QuantumDefense — Production Secrets (EXAMPLE TEMPLATE)
# ============================================================
# Copy this file to secrets.env and fill in your real values.
# secrets.env is gitignored and must NEVER be committed.
# ============================================================

# Database password (set in RDS + Vault + all service DATABASE_URLs)
DB_PASSWORD="your-db-password-here"

# JWT signing key (used by auth-service to sign tokens)
JWT_SECRET="your-jwt-secret-here"

# HashiCorp Vault dev root token
VAULT_DEV_TOKEN="your-vault-token-here"

# Grafana admin password
GRAFANA_PASSWORD="your-grafana-password-here"

# AWS IAM static access key for Jenkins → ECR push.
# Run: aws iam create-access-key --user-name <your-iam-user>
JENKINS_AWS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
JENKINS_AWS_SECRET="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
