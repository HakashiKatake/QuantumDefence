# Root environment configuration example

# Database config
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/qdefense?schema=public

# Security config
JWT_SECRET=c2-top-secret-signing-key

# Secrets Manager (Vault) config
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-dev-token

# Logging
LOG_LEVEL=info
